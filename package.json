{
  "name": "claude-buddy-cli",
  "version": "0.1.0",
  "description": "Tamagotchi-style terminal companion for Claude Code",
  "type": "module",
  "bin": {
    "claude-buddy": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "postinstall": "tsup",
    "setup": "node dist/index.js install",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "react": "^18.3.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "@types/react": "^18.3.20",
    "tsx": "^4.19.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
